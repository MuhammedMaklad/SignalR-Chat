@using SignalRChatApp.Contracts
@{
    ViewData["Title"] = "Messages";
    ViewData["FullWidth"] = true;
}

<link rel="stylesheet" href="~/css/chat-modern.css" asp-append-version="true" />

<div class="chat-container-fluid">
    <!-- Mobile Sidebar Toggle -->
    <button class="chat-sidebar-toggle" id="sidebarToggle" aria-label="Open contacts">
        <i data-lucide="menu" class="fs-4"></i>
    </button>
    <div class="chat-sidebar-backdrop" id="sidebarBackdrop"></div>

    <!-- Contacts Sidebar -->
    <aside class="chat-contacts-sidebar" id="chatSidebar">
        <div class="chat-sidebar-search">
            <i data-lucide="search"></i>
            <input type="text" id="contactSearch" placeholder="Search messages..." aria-label="Search contacts and communities">
        </div>

        <div class="contact-list-container">
            <div class="contact-section-title">Direct Messages</div>
            <div id="userList">
                @if (ViewBag.Users is List<UserDto> users)
                {
                    @foreach (var user in users)
                    {
                        <div class="contact-item" role="button" tabindex="0" data-type="dm" data-id="@user.Id" data-name="@user.UserName">
                            <div class="contact-avatar">
                                @user.UserName[0].ToString().ToUpper()
                            </div>
                            <div class="contact-info">
                                <div class="contact-name">@user.UserName</div>
                                <div class="contact-status">Click to chat</div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="contact-section-title">Communities</div>
            <div id="groupList">
                @if (ViewBag.Groups is List<GroupDto> groups)
                {
                    @foreach (var group in groups)
                    {
                        <div class="contact-item" role="button" tabindex="0" data-type="group" data-id="@group.Id" data-name="@group.Name">
                            <div class="contact-avatar bg-secondary">
                                <i data-lucide="hash"></i>
                            </div>
                            <div class="contact-info">
                                <div class="contact-name">@group.Name</div>
                                <div class="contact-status">@group.MemberCount members</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </aside>

    <!-- Main Chat Area -->
    <section class="chat-main" id="chatMain">
        <!-- Default Empty State -->
        <div class="chat-empty-state" id="emptyState">
            <i data-lucide="message-square" aria-hidden="true" style="font-size: 4rem; opacity: 0.2;"></i>
            <h4>Your Messages</h4>
            <p>Select a contact or community to start chatting.</p>
        </div>

        <!-- Active Chat UI (Hidden by default) -->
        <div id="activeChatUI" style="display: none; flex-direction: column; flex: 1;">
            <header class="chat-main-header">
                <div class="active-chat-info">
                    <div class="contact-avatar" id="activeChatAvatar"></div>
                    <div>
                        <div class="contact-name" id="activeChatName">Select a chat</div>
                        <div class="contact-status" id="activeChatStatus">Online</div>
                    </div>
                </div>
                <div class="chat-actions">
                    <button class="btn btn-link text-muted" aria-label="Voice call"><i data-lucide="phone"></i></button>
                    <button class="btn btn-link text-muted" aria-label="Video call"><i data-lucide="video"></i></button>
                    <button class="btn btn-link text-muted" aria-label="Chat info"><i data-lucide="info"></i></button>
                </div>
            </header>

            <div class="messages-viewport" id="messagesList">
                <!-- Messages will be injected here -->
            </div>

            <footer class="chat-footer">
                <form id="chatForm">
                    <div class="chat-input-wrapper">
                        <button type="button" class="btn btn-link text-muted p-0" aria-label="Attach file"><i data-lucide="plus-circle" class="fs-5"></i></button>
                        <input type="text" id="messageInput" placeholder="Type a message..." autocomplete="off" aria-label="Type a message">
                        <button type="button" class="btn btn-link text-muted p-0" aria-label="Insert emoji"><i data-lucide="smile" class="fs-5"></i></button>
                        <button type="submit" class="send-btn" id="sendButton" aria-label="Send message">
                            <i data-lucide="send"></i>
                        </button>
                    </div>
                </form>
            </footer>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
    (function () {
        'use strict';

        var messagesList = document.getElementById('messagesList');
        var messageInput = document.getElementById('messageInput');
        var emptyState = document.getElementById('emptyState');
        var activeChatUI = document.getElementById('activeChatUI');
        var activeChatName = document.getElementById('activeChatName');
        var activeChatAvatar = document.getElementById('activeChatAvatar');
        var activeChatStatus = document.getElementById('activeChatStatus');
        var chatForm = document.getElementById('chatForm');
        var contactSearch = document.getElementById('contactSearch');
        var sidebarToggle = document.getElementById('sidebarToggle');
        var sidebarBackdrop = document.getElementById('sidebarBackdrop');
        var chatSidebar = document.getElementById('chatSidebar');

        var currentChat = null;
        var previousGroupId = null;

        function formatTime(date) {
            return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }

        function escapeHtml(text) {
            var div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function appendMessage(id, senderId, senderName, content, timestamp, isMine) {
            var time = formatTime(new Date(timestamp));

            var wrapper = document.createElement('div');
            wrapper.className = 'msg-wrapper ' + (isMine ? 'sent' : 'received');
            wrapper.dataset.messageId = id;

            var senderHtml = isMine ? '' : '<span class="msg-meta fw-bold mb-1">' + escapeHtml(senderName) + '</span>';

            wrapper.innerHTML =
                senderHtml +
                '<div class="msg-bubble shadow-sm">' +
                    escapeHtml(content) +
                '</div>' +
                '<span class="msg-meta">' + time + '</span>';

            messagesList.appendChild(wrapper);
            messagesList.scrollTop = messagesList.scrollHeight;
        }

        function showChatUI(name, isGroup) {
            emptyState.style.display = 'none';
            activeChatUI.style.display = 'flex';
            activeChatName.textContent = name;

            if (isGroup) {
                activeChatAvatar.className = 'contact-avatar bg-secondary';
                activeChatAvatar.innerHTML = '<i data-lucide="hash"></i>';
                activeChatStatus.textContent = 'Community';
            } else {
                activeChatAvatar.className = 'contact-avatar';
                activeChatAvatar.textContent = name[0].toUpperCase();
                activeChatStatus.textContent = 'Direct Message';
            }

            messagesList.innerHTML = '';
            lucide.createIcons();
        }
...

        function loadConversation(userId, name) {
            showChatUI(name, false);
            currentChat = { type: 'dm', userId: userId };
            messageInput.placeholder = 'Message ' + name;

            fetch('/Chat/GetConversation?userId=' + encodeURIComponent(userId))
                .then(function (response) {
                    if (!response.ok) throw new Error('Failed to load messages');
                    return response.json();
                })
                .then(function (messages) {
                    messages.forEach(function (m) {
                        appendMessage(m.id, m.senderId, m.senderName, m.content, m.timestamp, m.isMine);
                    });
                })
                .catch(function () {
                    messagesList.innerHTML = '<div class="chat-empty-state"><p>Failed to load messages. Please try again.</p></div>';
                });
        }

        function loadGroupMessages(groupId, name) {
            showChatUI(name, true);
            currentChat = { type: 'group', groupId: groupId };
            messageInput.placeholder = 'Message #' + name;

            connection.invoke('JoinGroup', groupId).catch(function (err) {
                console.error(err);
            });

            fetch('/Chat/GetGroupMessages?groupId=' + groupId)
                .then(function (response) {
                    if (!response.ok) throw new Error('Failed to load messages');
                    return response.json();
                })
                .then(function (messages) {
                    messages.forEach(function (m) {
                        appendMessage(m.id, m.senderId, m.senderName, m.content, m.timestamp, m.isMine);
                    });
                })
                .catch(function () {
                    messagesList.innerHTML = '<div class="chat-empty-state"><p>Failed to load messages. Please try again.</p></div>';
                });
        }

        var connection = new signalR.HubConnectionBuilder()
            .withUrl('/chatHub')
            .withAutomaticReconnect()
            .build();

        connection.on('ReceiveMessage', function (message) {
            if (currentChat && currentChat.type === 'dm' && (currentChat.userId === message.senderId || message.isMine)) {
                appendMessage(message.id, message.senderId, message.senderName, message.content, message.timestamp, message.isMine);
            }
        });

        connection.on('ReceiveGroupMessage', function (message) {
            if (currentChat && currentChat.type === 'group' && currentChat.groupId === message.groupId) {
                appendMessage(message.id, message.senderId, message.senderName, message.content, message.timestamp, message.isMine);
            }
        });

        connection.start().catch(function (err) {
            console.error(err.toString());
        });

        function handleContactActivation(el) {
            document.querySelectorAll('.contact-item').forEach(function (item) {
                item.classList.remove('active');
            });
            el.classList.add('active');

            var type = el.dataset.type;
            var id = el.dataset.id;
            var name = el.dataset.name;

            if (type === 'dm') {
                if (previousGroupId) {
                    connection.invoke('LeaveGroup', previousGroupId).catch(function (err) {
                        console.error(err);
                    });
                    previousGroupId = null;
                }
                loadConversation(id, name);
            } else {
                if (previousGroupId && previousGroupId !== parseInt(id)) {
                    connection.invoke('LeaveGroup', previousGroupId).catch(function (err) {
                        console.error(err);
                    });
                }
                loadGroupMessages(parseInt(id), name);
                previousGroupId = parseInt(id);
            }

            closeSidebar();
        }

        function closeSidebar() {
            chatSidebar.classList.remove('open');
            sidebarBackdrop.classList.remove('active');
        }

        document.querySelectorAll('.contact-item').forEach(function (item) {
            item.addEventListener('click', function () {
                handleContactActivation(this);
            });

            item.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    handleContactActivation(this);
                }
            });
        });

        chatForm.addEventListener('submit', function (e) {
            e.preventDefault();
            var msg = messageInput.value.trim();
            if (!msg || !currentChat) return;

            if (currentChat.type === 'dm') {
                connection.invoke('SendMessageToUser', currentChat.userId, msg).catch(function (err) {
                    console.error(err.toString());
                });
            } else if (currentChat.type === 'group') {
                connection.invoke('SendMessageToGroup', currentChat.groupId, msg).catch(function (err) {
                    console.error(err.toString());
                });
            }
            messageInput.value = '';
            messageInput.focus();
        });

        contactSearch.addEventListener('keyup', function () {
            var value = this.value.toLowerCase();
            document.querySelectorAll('.contact-item').forEach(function (item) {
                var name = item.dataset.name.toLowerCase();
                item.style.display = name.indexOf(value) > -1 ? '' : 'none';
            });
        });

        sidebarToggle.addEventListener('click', function () {
            chatSidebar.classList.add('open');
            sidebarBackdrop.classList.add('active');
        });

        sidebarBackdrop.addEventListener('click', closeSidebar);
    })();
    </script>
}
