@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <!-- Welcome Card -->
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-brand-gradient">
            <div class="card-body p-4 p-md-5 text-white">
                <div class="row align-items-center">
                    <div class="col-md-8 text-center text-md-start">
                        <h1 class="display-5 fw-800 mb-3">Welcome to SignalRChatApp</h1>
                        <p class="lead opacity-75 mb-4">Experience real-time communication with your communities and friends. Fast, secure, and modern.</p>
                        <div class="d-flex gap-3 justify-content-center justify-content-md-start">
                            <a asp-controller="Chat" asp-action="Index" class="btn btn-white px-4 py-2 rounded-pill fw-600">
                                <i class="bi bi-chat-dots me-2"></i>Start Chatting
                            </a>
                            <a asp-controller="Groups" asp-action="Index" class="btn btn-outline-white px-4 py-2 rounded-pill fw-600">
                                <i class="bi bi-hash me-2"></i>Communities
                            </a>
                        </div>
                    </div>
                    <div class="col-md-4 d-none d-md-block text-center">
                        <i class="bi bi-chat-square-text" style="font-size: 10rem; opacity: 0.15;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats / Feature Cards -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 transition-hover">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="bg-primary-subtle text-primary rounded-3 p-3">
                    <i class="bi bi-lightning-charge-fill fs-3"></i>
                </div>
                <h5 class="fw-700 mb-0">Real-time</h5>
            </div>
            <p class="text-muted small mb-0">Powered by SignalR for instant message delivery across all connected clients.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 transition-hover">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="bg-success-subtle text-success rounded-3 p-3">
                    <i class="bi bi-shield-check fs-3"></i>
                </div>
                <h5 class="fw-700 mb-0">Secure</h5>
            </div>
            <p class="text-muted small mb-0">Robust authentication and authorization using ASP.NET Core Identity services.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 transition-hover">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="bg-info-subtle text-info rounded-3 p-3">
                    <i class="bi bi-people-fill fs-3"></i>
                </div>
                <h5 class="fw-700 mb-0">Communities</h5>
            </div>
            <p class="text-muted small mb-0">Create or join groups to collaborate and stay in touch with your favorite people.</p>
        </div>
    </div>

    <!-- How it works -->
    <div class="col-12 mt-5">
        <div class="text-center mb-5">
            <h2 class="fw-800">Stay Connected Everywhere</h2>
            <p class="text-muted">A seamless experience designed for modern communication needs.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3 text-center">
                <div class="feature-icon-circle mx-auto mb-3"><i class="bi bi-phone"></i></div>
                <h6 class="fw-700">Responsive Design</h6>
                <p class="text-muted smaller">Perfectly optimized for mobile, tablet, and desktop viewports.</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center">
                <div class="feature-icon-circle mx-auto mb-3"><i class="bi bi-clock-history"></i></div>
                <h6 class="fw-700">Message History</h6>
                <p class="text-muted smaller">Access your entire conversation history whenever you need it.</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center">
                <div class="feature-icon-circle mx-auto mb-3"><i class="bi bi-palette"></i></div>
                <h6 class="fw-700">Premium UI</h6>
                <p class="text-muted smaller">A clean, focused interface that maximizes your productivity.</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center">
                <div class="feature-icon-circle mx-auto mb-3"><i class="bi bi-cpu"></i></div>
                <h6 class="fw-700">High Performance</h6>
                <p class="text-muted smaller">Built on ASP.NET Core 10 for industry-leading speed and scale.</p>
            </div>
        </div>
    </div>
</div>
