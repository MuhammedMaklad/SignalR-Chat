@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden text-center">
            <div class="card-body p-5">
                <div class="mb-4">
                    <div class="d-inline-flex bg-danger-subtle text-danger rounded-circle p-4 mb-3">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
                    </div>
                    <h1 class="fw-800 text-dark mb-2">Oops!</h1>
                    <h5 class="text-muted mb-4">An error occurred while processing your request.</h5>
                </div>

                @if (Model.ShowRequestId)
                {
                    <div class="bg-light p-3 rounded-3 mb-4 text-start">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi bi-info-circle-fill text-muted"></i>
                            <span class="fw-700 text-muted small uppercase letter-spacing-1">Technical Reference</span>
                        </div>
                        <code class="text-break fs-6">@Model.RequestId</code>
                    </div>
                }

                <div class="d-grid gap-2">
                    <a href="javascript:history.back()" class="btn btn-primary py-2 rounded-pill fw-600">
                        <i class="bi bi-arrow-left me-2"></i>Go Back
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary py-2 rounded-pill fw-600">
                        <i class="bi bi-house-door me-2"></i>Return Home
                    </a>
                </div>

                <div class="mt-5 pt-4 border-top">
                    <p class="text-muted smaller mb-0 text-start">
                        <strong>Development Mode:</strong> Swapping to the <strong>Development</strong> environment will display more detailed information.
                        The development environment should not be enabled for deployed applications.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>


