@{
    ViewData["Title"] = "Create Community";
}

<link rel="stylesheet" href="~/css/communities-modern.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/auth-modern.css" asp-append-version="true" />

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-5">
        <div class="form-container-card">
            <div class="form-header-gradient">
                <i class="bi bi-plus-circle"></i>
                <h2 class="fw-800 mb-1">Create Community</h2>
                <p class="mb-0 opacity-75">Start a new hub for your team or friends</p>
            </div>

            <div class="form-body-modern">
                <form asp-controller="Groups" asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-group-modern">
                        <label for="name" class="form-label-modern">Community Name</label>
                        <input type="text" id="name" name="name" class="form-control-modern" placeholder="e.g. Engineering Team, Gaming Squad..." maxlength="100" required />
                    </div>

                    <div class="alert alert-info border-0 rounded-3 small d-flex align-items-center gap-3">
                        <i class="bi bi-info-circle-fill fs-4"></i>
                        <span>As the creator, you will be the owner of this community and can invite others later.</span>
                    </div>

                    <div class="mt-4 d-grid gap-2">
                        <button type="submit" class="btn-auth">Create Community</button>
                        <a asp-controller="Groups" asp-action="Index" class="btn btn-link text-muted text-decoration-none small">
                            Cancel and go back
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
